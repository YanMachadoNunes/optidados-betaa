  // prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

// Usuários do sistema
model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String?
  image     String?
  plan      String   @default("FREE") // FREE, BASIC, STANDARD, PREMIUM
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sales     Sale[]
  orders    Order[]
}


// 1. Clientes
model Customer {
  id        String   @id @default(uuid())
  name      String
  phone     String?
  email     String?
  cpf       String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sales     Sale[]
  orders    Order[]
  prescriptions Prescription[]
}

// 2. Produtos (Estoque)
model Product {
  id          String   @id @default(uuid())
  name        String
  price       Decimal
  costPrice   Decimal
  stock       Int      @default(0)
  category    String
  labCode     String?  // Código do laboratório (para lentes)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  saleItems   SaleItem[]
  orderItems  OrderItem[]
  orderFrame  Order?
}

model Sale {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id])

  totalAmount   Decimal   @db.Decimal(10, 2)
  status        String    @default("PENDING")
  paymentMethod String?
  createdAt     DateTime  @default(now())

  items         SaleItem[]
}

model SaleItem {
  id          String   @id @default(uuid())
  saleId      String
  sale        Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)

  productId   String
  product     Product  @relation(fields: [productId], references: [id])

  quantity    Int
  unitPrice   Decimal  @db.Decimal(10, 2)
}

model Order {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  customerId    String
  customer      Customer  @relation(fields: [customerId], references: [id])

  prescriptionId String?  @unique
  prescription  Prescription? @relation(fields: [prescriptionId], references: [id])

  frameId       String?   @unique
  frame         Product?  @relation(fields: [frameId], references: [id])

  totalAmount   Decimal   @db.Decimal(10, 2)
  status        String    @default("PENDING") // PENDING, IN_ASSEMBLY, READY, DELIVERED
  paymentMethod String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime @updatedAt

  items         OrderItem[]
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product  @relation(fields: [productId], references: [id])

  quantity  Int
  unitPrice Decimal  @db.Decimal(10, 2)
}

model Prescription {
  id            String   @id @default(uuid())
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id])

  doctorName    String?
  crm           String?

  // Olho Direito
  odSpherical   Decimal  @default(0)
  odCylindrical Decimal  @default(0)
  odAxis        Int      @default(0)

  // Olho Esquerdo
  oeSpherical   Decimal  @default(0)
  oeCylindrical Decimal  @default(0)
  oeAxis        Int      @default(0)

  // Adições (perto)
  additionOD    Decimal  @default(0)
  additionOE    Decimal  @default(0)
  
  examDate      DateTime @default(now())
  dueDate       DateTime?
  createdAt     DateTime @default(now())

  order         Order?
}

// No seu schema.prisma
